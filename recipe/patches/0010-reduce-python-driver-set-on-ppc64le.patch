--- python/tensorstore/BUILD
+++ python/tensorstore/BUILD
@@ -18,6 +18,26 @@ exports_files([
     "cc_test_driver_main.py",
 ])
 
+# The full Python extension overflows PPC64 REL24 branch ranges once the
+# complete kvstore/cloud/ocdbt stack is linked in. Keep the local and HTTP
+# oriented drivers on ppc64le so `import tensorstore` still works while
+# avoiding the grpc/aws-heavy backends that push the shared object over the
+# linker limit.
+tensorstore_cc_library(
+    name = "ppc64le_drivers",
+    deps = [
+        "//tensorstore/driver:all_drivers",
+        "//tensorstore/kvstore/file",
+        "//tensorstore/kvstore/http",
+        "//tensorstore/kvstore/kvstack",
+        "//tensorstore/kvstore/memory",
+        "//tensorstore/kvstore/neuroglancer_uint64_sharded",
+        "//tensorstore/kvstore/zip",
+        "//tensorstore/kvstore/zarr3_sharding_indexed",
+    ],
+    alwayslink = True,
+)
+
 PYI_FILES = glob(["**/*.pyi"])
 
 doctest_test(
@@ -53,22 +73,28 @@ pybind11_py_extension(
         ":index_space",
         ":kvstore",
         ":numpy",
-        ":ocdbt",
         ":python_imports",
         ":serialization",
         ":spec",
         ":stack",
         ":tensorstore_class",
         ":tensorstore_module_components",
         ":transaction",
         ":unit",
         ":virtual_chunked",
         ":write_futures",
-        "//tensorstore:all_drivers",
         "@abseil-cpp//absl/base:log_severity",
         "@abseil-cpp//absl/debugging:leak_check",
         "@abseil-cpp//absl/log:globals",
         "@abseil-cpp//absl/log:initialize",
         "@com_github_pybind_pybind11//:pybind11",
-    ],
+    ] + select({
+        "@platforms//cpu:ppc64le": [
+            ":ppc64le_drivers",
+        ],
+        "//conditions:default": [
+            ":ocdbt",
+            "//tensorstore:all_drivers",
+        ],
+    }),
 )
