+    if lib_dir == None or lib_dir == "":
+        conda_prefix = repo_utils.getenv(ctx, "CONDA_PREFIX")
+        if conda_prefix:
+            lib_dir = conda_prefix + "/lib"
+    return lib_dir
+
+def _symlink_system_libs(ctx, logger, lib_names):
+    """Symlinks specific library files from system lib directory."""
+    lib_dir = _detect_lib_dir(ctx)
+    if lib_dir == None or lib_dir == "":
+        logger.warn(lambda: "Could not detect system lib directory")
+        return
+
+    lib_path = ctx.path(lib_dir)
+    if not lib_path.exists:
+        logger.warn(lambda: "Lib dir not found: {}".format(lib_dir))
+        return
+
+    for lib_name in lib_names:
+        for ext in [".so", ".dylib", ".a"]:
+            lib_file = lib_dir + "/lib" + lib_name + ext
+            lib_file_path = ctx.path(lib_file)
+            if lib_file_path.exists:
+                repo_utils.watch(ctx, lib_file_path)
+                ctx.symlink(lib_file_path, "lib" + lib_name + ext)
+                logger.info(lambda: "Symlinked: {}".format(lib_file))
+
+def _symlink_system_include_dir(ctx, logger):
+    """Symlinks the system include directory."""
+    include_dir = _detect_include_dir(ctx)
+    if include_dir == None or include_dir == "":
+        logger.warn(lambda: "Could not detect system include directory")
+        return
+    include_path = ctx.path(include_dir)
+    if not include_path.exists:
+        logger.warn(lambda: "Include dir not found: {}".format(include_dir))
+        return
+    repo_utils.watch_tree(ctx, include_path)
+    ctx.symlink(include_path, "include")
+    logger.info(lambda: "Using system headers from: {}".format(include_dir))
