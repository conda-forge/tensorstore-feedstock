+def _detect_include_dir(ctx):
+    """Detects the system include directory path."""
+    include_dir = repo_utils.getenv(ctx, "TENSORSTORE_INCLUDE_DIR")
+    if include_dir == None or include_dir == "":
+        prefix = repo_utils.getenv(ctx, "PREFIX")
+        if prefix:
+            include_dir = prefix + "/include"
+    if include_dir == None or include_dir == "":
+        conda_prefix = repo_utils.getenv(ctx, "CONDA_PREFIX")
+        if conda_prefix:
+            include_dir = conda_prefix + "/include"
+    return include_dir
+
+def _detect_lib_dir(ctx):
+    """Detects the system library directory path."""
+    lib_dir = repo_utils.getenv(ctx, "TENSORSTORE_LIB_DIR")
+    if lib_dir == None or lib_dir == "":
+        prefix = repo_utils.getenv(ctx, "PREFIX")
+        if prefix:
